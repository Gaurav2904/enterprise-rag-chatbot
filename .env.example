# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Model settings ────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/all-mpnet-base-v2
EMBED_DEVICE=cpu          # set to "cuda" if GPU is available

# ── Vector store ──────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_WINDOW_K=6          # number of previous exchanges to keep in context

# ── Debug ─────────────────────────────────────────────────────────────────────
CHAIN_VERBOSE=0            # set to 1 to enable LangChain chain logging
